    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/prodotti?select=*",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_ANON_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "n4",
      "name": "Read PRODOTTI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [560, 400],
      "credentials": { "httpHeaderAuth": { "id": "SUPABASE", "name": "Supabase API" } },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const row = ($('Read CALENDARIO Row').first().json[0]) || {};\nconst brand = ($('Read BRAND').first().json[0]) || {};\nconst products = $('Read PRODOTTI').first().json || [];\nconst product = products.find(p => p.product_id === row.product_id) || {};\nreturn [{ json: { row, brand, product } }];"
      },
      "id": "n5",
      "name": "Merge Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [780, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 4000,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Sei content strategist Instagram carousel fashion. Crea carosello 5-7 slide.\\n\\nBRAND:\\n\" + JSON.stringify($json.brand) + \"\\n\\nPRODOTTO:\\n\" + JSON.stringify($json.product) + \"\\n\\nIDEA:\\n\" + JSON.stringify($json.row) + \"\\n\\nRegole: slide 1=hook, slide 2=problema, slide 3=prodotto, slide 4=styling, slide 5=beneficio, slide finale=CTA. Testi brevi mobile.\\n\\nOutput SOLO JSON: {\\\"titolo_carosello\\\":\\\"\\\",\\\"numero_slide\\\":6,\\\"slides\\\":[{\\\"numero\\\":1,\\\"testo\\\":\\\"\\\",\\\"visual\\\":\\\"\\\"}]}\"\n    }\n  ]\n}",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "n6",
      "name": "Claude API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 300],
      "credentials": { "httpHeaderAuth": { "id": "ANTHROPIC", "name": "Anthropic x-api-key" } },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const txt = $json.content?.[0]?.text || '';\nconst m = txt.match(/\\{[\\s\\S]*\\}/);\nif (!m) throw new Error('No JSON in response');\nconst parsed = JSON.parse(m[0]);\nconst row = $('Merge Context').first().json.row;\nreturn [{ json: { id_contenuto: row.id_contenuto, struttura: JSON.stringify(parsed), titolo: parsed.titolo_carosello || '' } }];"
      },
      "id": "n7",
      "name": "Parse JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1220, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/calendario?id_contenuto=eq.{{ $json.id_contenuto }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_ANON_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"formato\": \"carousel\", \"note\": {{ JSON.stringify($json.struttura) }}, \"tema\": \"{{ $json.titolo }}\", \"status\": \"DA_APPROVARE\" }",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "n8",
      "name": "Update Row",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 300],
      "credentials": { "httpHeaderAuth": { "id": "SUPABASE", "name": "Supabase API" } },
      "continueOnFail": true
    }
  ],
  "connections": {
