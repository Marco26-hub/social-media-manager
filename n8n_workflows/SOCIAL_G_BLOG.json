        "jsCode": "const txt = $json.content?.[0]?.text || '';\nconst m = txt.match(/\\{[\\s\\S]*\\}/);\nif (!m) throw new Error('No JSON');\nconst parsed = JSON.parse(m[0]);\nreturn [{ json: parsed }];"
      },
