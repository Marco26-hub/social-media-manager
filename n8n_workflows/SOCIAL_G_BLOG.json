        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 4000,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Sei content writer SEO senior brand fashion. Scrivi articolo blog 800-1200 parole.\\n\\nBRAND:\\n\" + JSON.stringify($json.brand) + \"\\n\\nTOPIC:\\n\" + JSON.stringify($json.topic) + \"\\n\\nPRODOTTI:\\n\" + JSON.stringify($json.products) + \"\\n\\nSEO: H1 50-60ch + meta desc 140-160ch + 3-5 H2 + 800-1200 parole + densità keyword 1-2%.\\nGEO: liste numerate, FAQ section, dati specifici, tono autoritativo.\\n\\nOutput SOLO JSON: {\\\"slug\\\":\\\"\\\",\\\"meta_title\\\":\\\"\\\",\\\"meta_description\\\":\\\"\\\",\\\"h1\\\":\\\"\\\",\\\"intro\\\":\\\"\\\",\\\"sezioni\\\":[{\\\"h2\\\":\\\"\\\",\\\"paragrafi\\\":[],\\\"lista_punti\\\":[]}],\\\"faq\\\":[{\\\"domanda\\\":\\\"\\\",\\\"risposta\\\":\\\"\\\"}],\\\"cta_finale\\\":\\\"\\\",\\\"keywords_target\\\":[],\\\"prodotti_linkati\\\":[],\\\"tempo_lettura_min\\\":5,\\\"status\\\":\\\"DA_APPROVARE\\\"}\"\n    }\n  ]\n}",
        "options": { "response": { "response": { "neverError": true } } }
      },
